{
  "manifest_version": 3,
  "name": "Default Homepage",
  "version": "1.0.0",
  "description": "Set a default address that opens whenever you open a new browser tab.",
  "permissions": ["storage", "tabs"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Default Homepage Settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
